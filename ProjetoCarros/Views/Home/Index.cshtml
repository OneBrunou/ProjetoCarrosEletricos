            <div class="carousel-caption d-none d-md-block">
                <h5>Interior Tecnológico</h5>
                <p>Painel digital e acabamento premium.</p>
            </div>
        </div>

        <!-- SLIDE 8 -->
        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/Byd/Byd_Song_Plus_Lateral.png" class="d-block w-100" alt="Byd Song Plus Lateral">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Song Plus</h5>
                <p>Design sofisticado em cada detalhe.</p>
            </div>
        </div>

        <!-- SLIDE 9 -->
        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/Byd/Byd_Song_Plus_Rua.png" class="d-block w-100" alt="BYD Song Plus">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Seal</h5>
                <p>Performance e esportividade elétrica.</p>
            </div>
        </div>

        <!-- SLIDE 10 -->
        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/imagens/carros/9ef4e466-241c-415f-ba10-0df2c4cbb945.png" class="d-block w-100" alt="BYD Song Plus Traseira">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Seal</h5>
                <p>Visual esportivo e futurista.</p>
            </div>
        </div>

    </div>

    <!-- Controles -->
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
        <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
        <span class="visually-hidden">Próximo</span>
    </button>

</div>

<!-- Foco em Elétricos -->
<section class="foco-eletricos-section">


<!-- Foco em Elétricos -->
<section class="foco-eletricos-section">


<footer class="border-top footer text-muted">


    <div class="container">
        <h2 class="foco-eletricos-titulo">FOCO TOTAL EM MOBILIDADE ELÉTRICA</h2>
        <p class="foco-eletricos-texto">
            A ETEC Motors nasceu com um propósito claro: ser referência em veículos elétricos
            e híbridos em São Paulo. Não somos apenas mais uma concessionária, somos especialistas
            dedicados a entender e atender quem busca eficiência, tecnologia de ponta e zero
            emissões no dia a dia.
        </p>
        <p class="foco-eletricos-texto">
            Cada veículo da nossa frota passa por uma curadoria criteriosa, e nossa equipe é
            treinada para te guiar com transparência por toda a jornada, da escolha do carro ao
            suporte técnico especializado no pós-venda.
        </p>

    </div>
</section>

<!-- Cards Elétricos / Híbridos -->
<section class="frota-cards-section">
    <div class="row g-0">
        <div class="col-12 col-md-6">
            <div class="frota-card frota-card-eletrico">
                <img src="~/images/carros/Carroeletrico.jpg" class="frota-card-img" alt="Carros 100% Elétricos">
                <div class="frota-card-overlay">
                    <span class="frota-card-tag">100% ELÉTRICOS</span>
                    <h3 class="frota-card-titulo">Energia pura, zero emissões</h3>
                    <p class="frota-card-desc">Tecnologia 100% elétrica para quem quer estar à frente do seu tempo.</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6">
            <div class="frota-card frota-card-hibrido">
                <img src="~/images/carros/CarroHibrido.jpg" class="frota-card-img" alt="Carros Híbridos">
                <div class="frota-card-overlay">
                    <span class="frota-card-tag">HÍBRIDOS</span>
                    <h3 class="frota-card-titulo">O melhor dos dois mundos</h3>
                    <p class="frota-card-desc">Autonomia estendida e eficiência sem abrir mão da performance.</p>
                </div>
            </div>
        </div>
    </div>

    </div>
</section>

