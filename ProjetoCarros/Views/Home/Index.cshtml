@{
    ViewData["Title"] = "Home Page";
}
@section Scripts {
    <script src="~/js/splash.js" asp-append-version="true"></script>
    <script src="~/js/CarroselVideo.js" asp-append-version="true"></script>

}

<link rel="stylesheet" href="~/css/carrossel.css" />

<div id="splash-overlay">
    <div id="splash-logo">
        <img src="~/images/logo.png" alt="Logo" />
    </div>
</div>

<div id="carouselHome" class="carousel slide" data-bs-ride="false">

    <!-- Indicadores -->
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="2"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="3"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="4"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="5"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="6"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="7"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="8"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="9"></button>
        <button type="button" data-bs-target="#carouselHome" data-bs-slide-to="10"></button>
    </div>

    <!-- Slides -->
    <div class="carousel-inner">

        <!-- SLIDE 0: VÍDEO (primeiro) -->
        <div class="carousel-item active" data-bs-interval="false" id="slide-video" style="position: relative;">
            <video id="carouselVideo"
                   src="~/images/Porsche30seg.mp4"
                   class="d-block w-100"
                   style="object-fit: cover; max-height: 600px;"
                   muted
                   playsinline>
            </video>
            <!-- Overlay de texto e botão -->
            <div style="
                position: absolute;
                inset: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
                background: linear-gradient(to bottom, rgba(0,0,0,0.15), rgba(0,0,0,0.45));
                padding: 1rem;
            ">
                <h1 style="
                    color: #fff;
                    font-size: clamp(1.6rem, 4vw, 3rem);
                    font-weight: 700;
                    letter-spacing: 0.04em;
                    text-shadow: 0 2px 12px rgba(0,0,0,0.6);
                    margin-bottom: 0.4rem;
                ">
                    Performance in the new Taycan
                </h1>
                <p style="
                    color: rgba(255,255,255,0.85);
                    font-size: clamp(0.95rem, 2vw, 1.2rem);
                    font-weight: 400;
                    text-shadow: 0 1px 6px rgba(0,0,0,0.5);
                    margin-bottom: 1.8rem;
                ">Sinta a emoção de dirigir o futuro.</p>
                <a asp-controller="Servicos" asp-action="Agendamentos"
                   style="
                    display: inline-block;
                    padding: 0.75rem 2.2rem;
                    background: transparent;
                    color: #fff;
                    border: 2px solid #fff;
                    border-radius: 0;
                    font-size: 0.95rem;
                    font-weight: 600;
                    letter-spacing: 0.1em;
                    text-transform: uppercase;
                    text-decoration: none;
                    transition: background 0.25s, color 0.25s;
                "
                   onmouseover="this.style.background='#fff'; this.style.color='#000';"
                   onmouseout="this.style.background='transparent'; this.style.color='#fff';">
                    Agendar Test Drive
                </a>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_Dolphin_Cinza_Concessionaria.png" class="d-block w-100" alt="BYD Dolphin">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Dolphin</h5>
                <p>Design moderno e tecnologia elétrica.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_Dolphin_Frente.png" class="d-block w-100" alt="BYD Dolphin Frente">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Dolphin</h5>
                <p>Visual frontal marcante.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_King_frente_preto.png" class="d-block w-100" alt="BYD King">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD King</h5>
                <p>Sedã híbrido de alta eficiência.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_King_Interior.png" class="d-block w-100" alt="BYD King Interior">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD King</h5>
                <p>Elegância em todos os ângulos.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_King_Lateral.png" class="d-block w-100" alt="Interior BYD King">
            <div class="carousel-caption d-none d-md-block">
                <h5>Interior Premium</h5>
                <p>Conforto e tecnologia para todos.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/carros/Byd_King_Traseira.png" class="d-block w-100" alt="BYD King Traseira">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Dolphin</h5>
                <p>Linhas modernas e aerodinâmicas.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/Byd/Byd_King_Traseira.png" class="d-block w-100" alt="Byd King Traseira">
            <div class="carousel-caption d-none d-md-block">
                <h5>Interior Tecnológico</h5>
                <p>Painel digital e acabamento premium.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/Byd/Byd_Song_Plus_Lateral.png" class="d-block w-100" alt="Byd Song Plus Lateral">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Song Plus</h5>
                <p>Design sofisticado em cada detalhe.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/images/Byd/Byd_Song_Plus_Rua.png" class="d-block w-100" alt="BYD Song Plus">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Seal</h5>
                <p>Performance e esportividade elétrica.</p>
            </div>
        </div>

        <div class="carousel-item" data-bs-interval="5000">
            <img src="~/imagens/carros/9ef4e466-241c-415f-ba10-0df2c4cbb945.png" class="d-block w-100" alt="BYD Song Plus Traseira">
            <div class="carousel-caption d-none d-md-block">
                <h5>BYD Seal</h5>
                <p>Visual esportivo e futurista.</p>
            </div>
        </div>

    </div>

    <!-- Botões -->
    <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
        <span class="visually-hidden">Anterior</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
        <span class="visually-hidden">Próximo</span>
    </button>

</div>


<footer class="border-top footer text-muted">
    <div class="container">
        &copy; 2026 - ProjetoCarros - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
    </div>
</footer>