<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjetoCarros</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/splash.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjetoCarros.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style="font-family: 'Inter', sans-serif;">

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-black py-0" style="min-height: 75px; font-family: 'Inter', sans-serif;">
            <div class="container justify-content-center">

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                data-bs-target="#mainNav" aria-controls="mainNav"
                aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-center gap-3" id="mainNav">

                    <a asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="~/images/logo.png" alt="Logo" style="height: 65px; width: auto;" />
                    </a>

                    <ul class="navbar-nav mb-2 mb-lg-0">

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3" href="#"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Modelos
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark border-0 rounded-0 border-top border-white border-2 mt-0" style="background-color: black;">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="TodosModelos">Todos os Modelos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="CarrosEletricos">Elétricos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="CarrosHibridos">Híbrido</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3" href="#"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Estoque
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark border-0 rounded-0 border-top border-white border-2 mt-0" style="background-color: black;">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="Novos">Novos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="SemiNovos">Seminovos</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3" href="#"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Serviços
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark border-0 rounded-0 border-top border-white border-2 mt-0" style="background-color: black;">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Servicos" asp-action="Agendamentos">Agendamentos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Servicos" asp-action="Financiamento">Financiamento</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Servicos" asp-action="TestDrive">Test Drive</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Servicos" asp-action="Carregamento">Carregamento</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white px-3" href="#"
                            role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Sobre
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark border-0 rounded-0 border-top border-white border-2 mt-0" style="background-color: black;">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Sobre" asp-action="QuemSomos">Quem Somos</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Sobre" asp-action="NossaMarca">Nossa Marca</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Sobre" asp-action="Contato">Contato</a></li>
                            </ul>
                        </li>

                    </ul>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            @if (User.FindFirst("NivelAcesso")?.Value == "Admin")
                            {
                                <a class="nav-link dropdown-toggle text-white px-3" href="#"
                                role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Gerenciar
                                </a>
                            }
                            else
                            {
                                <a class="nav-link dropdown-toggle text-white px-3" href="#"
                                role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Conta
                                </a>
                            }
                            <ul class="dropdown-menu dropdown-menu-dark border-0 rounded-0 border-top border-white border-2 mt-0" style="background-color: black;">
                                @if (User.FindFirst("NivelAcesso")?.Value == "Admin")
                                {
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Carros" asp-action="Gerenciar">Cadastrar</a></li>
                                }
                                <li><a class="dropdown-item" asp-area="" asp-controller="Usuario" asp-action="configuracoes">Configuraçoes</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Usuario" asp-action="Sair">Sair da Conta</a></li>
                            </ul>
                        </li>
                        <span class="text-white" style="cursor: pointer; font-size: 14px;">Olá, @User.Identity.Name</span>
                    }
                    else
                    {
                        <a asp-controller="Usuario" asp-action="Logar" class="btn btn-outline-light btn-sm px-3">↗ Entrar</a>
                    }

                </div>
            </div>
        </nav>
    </header>

    @RenderBody()

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/splash.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
