@{
    ViewData["Title"] = "Nossa Marca";
}

<section class="position-relative overflow-hidden text-white"
         style="background-image: url('/images/carros/ImgFundoSobre.png');
                background-size: cover;
                background-position: center;
                min-height: 600px;">

    <div class="position-absolute top-0 start-0 h-100"
         style="width: 60%;
                background: linear-gradient(to right, rgba(0,0,0,0.75) 60%, transparent 100%);
                z-index: 0;">
    </div>

    <div class="container position-relative py-5" style="z-index: 1;">
        <div class="col-md-6 pt-4">
            <h1 class="fw-bold text-uppercase mb-3" style="font-size: 3rem; letter-spacing: 0.05em; line-height: 1.1;">
                INOVAÇÃO EM MOVIMENTO
            </h1>
            <p style="font-size: 1.10rem; line-height: 1.8; opacity: 0.9;">
                Fundada em 2026, a ETEC Motors vem mudando o jogo desde então. A ETEC Motors
                Holding possui e administra uma série de marcas de veículos elétricos e híbridos: ETEC
                Auto, ETEC Volt, ETEC Hybrid, ETEC Urban e mais.
            </p>
        </div>

        <div class="row mt-5 pt-3" style="border-top: 1px solid rgba(255,255,255,0.2);">

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.9rem; opacity: 0.75; black">Vendas Globais ETEC Auto</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">18M+</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">
                    unidades desde 2026
                </p>
            </div>

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.9rem; opacity: 0.75;">Vendas da Holding Global ETEC Motors</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">2,17M</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">
                    unidades em 2026
                </p>
            </div>

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.9rem; opacity: 0.75;">
                    Veículos de nova energia da ETEC
                </p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">92% EM 2026</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">em relação ao ano anterior</p>
            </div>

            <div class="col-6 col-md-3 mb-4">
                <p class="mb-1" style="font-size: 0.9rem; opacity: 0.75;">
                    Veículos Elétricos Vendidos
                </p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">888K+</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">unidades em 2026</p>
            </div>

        </div>
    </div>
</section>

<section class="py-5 text-center" style="background-color: black;">
    <div class="container">

        <h2 class="fw-bold text-uppercase mb-4" style="letter-spacing: 0.15em;">
            ETEC MOTORS GROUP EM UM RELANCE
        </h2>

        <p class="mx-auto mb-4" style="max-width: 860px; line-height: 1.8;">
            A ETEC Motors Group é uma fabricante de veículos elétricos e híbridos sediada em São
            Paulo, Brasil, e foi fundada em 2026 como uma unidade subsidiária da ETEC Basilides de
            Godoy Holding (EBGH). O Grupo gerencia várias marcas, incluindo ETEC Auto, ETEC Volt
            e ETEC Hybrid. A ETEC Motors Group também é parceira estratégica de montadoras
            nacionais e internacionais do setor de mobilidade elétrica.
        </p>

        <a href="#" class="btn btn-dark px-4 py-2 mb-5">Ver mais</a>

        @* ===== CARDS ===== *@
        <div class="row g-4 justify-content-center">

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/empresa.webp" alt="Fortune 500"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">
                            Uma empresa referência desde sua fundação
                        </h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            No ranking das Maiores Montadoras do Brasil de 2026, a ETEC Motors Holding ficou em 1º
                            lugar entre as marcas estudantis, com uma receita simulada de R$ 55,86 milhões.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/LogoEtecMotors.png" alt="Brand Value"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">Uma das 10 maiores marcas do mundo</h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            A ETEC Motors Holding ficou em 1º lugar no Top 10 das Marcas de Portfólio de Veículos Elétricos Mais Valiosas de 2026.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/carrinhos.webp" alt="IATF"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">
                            Volume de vendas global de mais de 120 mil unidades
                        </h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            No final de outubro de 2026, a ETEC Auto se tornou a primeira marca de veículos elétricos da rede ETEC a ter sucesso na venda de mais de 100 mil unidades simuladas. No final de abril de 2026, as vendas globais acumuladas da ETEC Auto ultrapassaram 120 mil unidades.

                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
