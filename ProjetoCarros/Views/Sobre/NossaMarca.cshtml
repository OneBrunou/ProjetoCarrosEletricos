@{
    ViewData["Title"] = "Nossa Marca";
}

<section class="position-relative overflow-hidden text-white"
         style="background-image: url('/images/carros/ImgFundoSobre.png');
                background-size: cover;
                background-position: center;
                min-height: 600px;">

    <div class="position-absolute top-0 start-0 h-100"
         style="width: 60%;
                background: linear-gradient(to right, rgba(0,0,0,0.75) 60%, transparent 100%);
                z-index: 0;">
    </div>

    <div class="container position-relative py-5" style="z-index: 1;">
        <div class="col-md-6 pt-4">
            <h1 class="fw-bold text-uppercase mb-3" style="font-size: 3rem; letter-spacing: 0.05em; line-height: 1.1;">
                INOVAÇÃO EM MOVIMENTO
            </h1>
            <p style="font-size: 0.95rem; line-height: 1.8; opacity: 0.9;">
                Fundada em 1986, a Geely vem mudando o jogo desde então. A Geely Holding possui e administra
                uma série de marcas de automóveis icônicas: Geely Auto, Volvo, Polestar, Lotus, ZEEKR,
                Lynk & Co, London Electric Vehicle Company, Farizon e mais.
            </p>
        </div>

        <div class="row mt-5 pt-3" style="border-top: 1px solid rgba(255,255,255,0.2);">

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.8rem; opacity: 0.75;">Vendas Globais Geely Auto</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">18M+</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">unidades desde 1997</p>
            </div>

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.8rem; opacity: 0.75;">Vendas da Holding Global Geely</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">2,17M</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">unidades em 2024</p>
            </div>

            <div class="col-6 col-md-3 mb-4" style="border-right: 1px solid rgba(255,255,255,0.2);">
                <p class="mb-1" style="font-size: 0.8rem; opacity: 0.75;">Veículos de nova energia da Geely Holding</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">92% EM 2024</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">em relação ao ano anterior</p>
            </div>

            <div class="col-6 col-md-3 mb-4">
                <p class="mb-1" style="font-size: 0.8rem; opacity: 0.75;">Veículos de nova energia da Geely Holding</p>
                <h2 class="fw-bold mb-1" style="font-size: 2rem;">888K+</h2>
                <p style="font-size: 0.8rem; opacity: 0.75;">unidades em 2024</p>
            </div>

        </div>
    </div>
</section>

<section class="py-5 text-center" style="background-color: black;">
    <div class="container">

        <h2 class="fw-bold text-uppercase mb-4" style="letter-spacing: 0.15em;">
            GEELY AUTO GROUP EM UM RELANCE
        </h2>

        <p class="mx-auto mb-4" style="max-width: 860px; line-height: 1.8;">
            A Geely Auto Group é uma fabricante líder de automóveis sediada em Hangzhou, China,
            e foi fundada em 1997 como uma unidade subsidiária da Zhejiang Geely Holding Group (ZGH).
            O Grupo gerencia várias marcas líderes, incluindo Geely Auto, Lynk & Co e Zeekr.
            A Geely Auto Group também é parceira estratégica global da montadora nacional malaia PROTON.
        </p>

        <a href="#" class="btn btn-dark px-4 py-2 mb-5">Ver mais</a>

        @* ===== CARDS ===== *@
        <div class="row g-4 justify-content-center">

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/empresa.webp" alt="Fortune 500"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">Uma empresa Fortune 500 por 13 anos consecutivos</h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            Na lista Fortune Global 500 de 2022, o Geely Holding Group ficou em 229º lugar,
                            com uma receita de US$ 55,86 bilhões.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/LogoEtecMotors.png" alt="Brand Value"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">Uma das 10 maiores marcas do mundo</h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            O Geely Holding Group ficou em 8º lugar no Top 10 das Marcas de Portfólio de
                            Automóveis Mais Valiosas de 2022.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="bg-white rounded-3 overflow-hidden h-100">
                    <img src="/images/carrinhos.webp" alt="IATF"
                         class="w-100" style="height: 240px; object-fit: cover;" />
                    <div class="p-4 text-start">
                        <h5 class="fw-semibold mb-3 text-black">
                            Volume de vendas global de mais de 12 milhões
                        </h5>
                        <p style="font-size: 0.85rem; color: #555; line-height: 1.7;">
                            No final de outubro de 2020, a Geely Auto se tornou a primeira marca de automóveis chinesa a ter sucesso na venda de mais de 10 milhões de unidades globalmente. No final de abril de 2022, as vendas globais acumuladas da Geely Auto ultrapassaram 12 milhões.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>
﻿@*
