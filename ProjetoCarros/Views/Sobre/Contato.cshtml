@{
    ViewData["Title"] = "Contato";
}

<link rel="stylesheet" href="~/css/contato.css" />

<section class="contact-hero position-relative overflow-hidden text-white">

    <div class="position-absolute top-0 start-0 h-100 w-100 contact-hero-overlay"></div>

    <div class="container position-relative py-5 d-flex align-items-center contact-hero-inner">
        <div class="col-md-6 pt-4">
            <h1 class="fw-bold text-uppercase mb-2 contact-title">
                Contato
            </h1>
            <p class="mb-0 contact-subtitle">
                Fale com a equipe Etec Motors Brasil
            </p>
        </div>
    </div>
</section>

<section class="py-5">
    <div class="container">

        <div class="row g-4 mb-5">
            <div class="col-sm-6 col-lg-3">
                <div class="card contact-card h-100 border">
                    <i class="bi bi-building card-icon"></i>
                    <p class="card-label">Empresa</p>
                    <p class="card-value fw-semibold">ETEC Motors Brasil</p>
                    <p class="card-hint">Concessionária de veículos elétricos</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card contact-card h-100 border">
                    <i class="bi bi-envelope card-icon"></i>
                    <p class="card-label">E-mail</p>
                    <p class="card-value fw-semibold">etecbrasil@motors.com</p>
                    <p class="card-hint">Resposta em até 24h</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card contact-card h-100 border">
                    <i class="bi bi-telephone card-icon"></i>
                    <p class="card-label">SAC</p>
                    <p class="card-value fw-semibold">0800 000 0000</p>
                    <p class="card-hint">Seg–Sex, 8h às 18h</p>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card contact-card h-100 border">
                    <i class="bi bi-headset card-icon"></i>
                    <p class="card-label">SAC ETEC Motors</p>
                    <p class="card-value fw-semibold">sac@etecmotorsbrasil.com.br</p>
                    <p class="card-hint">Suporte especializado</p>
                </div>
            </div>
        </div>

    </div>
</section>
