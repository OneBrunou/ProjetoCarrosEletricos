@{
    ViewData["Title"] = "Novo Agendamento";
}
<link rel="stylesheet" href="~/css/Agendamento.css" />


<section class="ag-hero">
    <div class="container">
        <div class="row align-items-center gy-5">

            <div class="col-lg-6">
                <h1 class="ag-titulo">NOVO AGENDAMENTO</h1>
                <p class="ag-subtitulo">Marque um novo horário de atendimento</p>

                <a asp-controller="Servicos" asp-action="Agendar" class="ag-btn-agendar">
                    Agendar agora
                    <i class="bi bi-arrow-right"></i>
                </a>
            </div>

            <div class="col-lg-6">
                <div class="ag-imagem-wrapper">
                    <img src="~/images/EtecMotorsAgendamento.png" alt="Agendamento ETEC Motors" class="ag-imagem">
                </div>
            </div>

        </div>
    </div>
</section>

<section class="ag-passos-section">
    <div class="container">
        <div class="ag-passos-card">
            <div class="row gy-4">

                <div class="col-md-4">
                    <div class="ag-passo">
                        <div class="ag-passo-numero">1</div>
                        <div>
                            <h3 class="ag-passo-titulo">Escolha uma loja e horário</h3>
                            <p class="ag-passo-texto">Selecione a loja mais próxima de você e o melhor horário disponível</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="ag-passo">
                        <div class="ag-passo-numero">2</div>
                        <div>
                            <h3 class="ag-passo-titulo">Preencha seus dados</h3>
                            <p class="ag-passo-texto">Informe seus dados pessoais e informações do seu veículo para o atendimento</p>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="ag-passo">
                        <div class="ag-passo-numero">3</div>
                        <div>
                            <h3 class="ag-passo-titulo">Receba sua confirmação</h3>
                            <p class="ag-passo-texto">Você receberá um ID de agendamento para consultar, remarcar ou cancelar</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
