@model ProjetoCarros.Models.Carro
@*
  

    IMPORTANTE: O enctype="multipart/form-data" é OBRIGATÓRIO para o upload
    de imagem funcionar. Sem ele, o IFormFile chega null no controller.

    asp-for="Nome" faz duas coisas:
      1. Gera o atributo name="Nome" correto para o binding
      2. Exibe erros de validação vinculados àquele campo
*@
@{
    ViewData["Title"] = "Novo Carro";
}

<!-- Breadcrumb simples para voltar -->
<div style="margin-bottom:1.5rem">
    <a asp-action="Gerenciar" style="color:var(--muted);font-size:0.875rem">← Voltar para Gerenciar</a>
</div>

<div class="eyebrow">// admin</div>
<h1 class="page-title" style="margin-bottom:1.75rem">Cadastrar novo carro</h1>

<!--
    FORMULÁRIO
    method="post" — envia os dados via POST para CarrosController.Criar(Carro, IFormFile)
    enctype="multipart/form-data" — necessário para enviar arquivos (imagem)
    asp-antiforgery="true" — gera o campo oculto __RequestVerificationToken
-->
<form asp-action="Criar" method="post" enctype="multipart/form-data" style="max-width:640px">
    @Html.AntiForgeryToken()

    <!-- Resumo de erros de validação (server-side) -->
    <div asp-validation-summary="ModelOnly"></div>

    <!-- NOME DO CARRO -->
    <div class="form-group">
        <label class="form-label" asp-for="Nome">Nome do modelo</label>
        <input class="form-control" asp-for="Nome" placeholder="Ex: BYD Seal" />
        <span asp-validation-for="Nome" class="field-validation-error"></span>
    </div>

    <!-- MARCA — select com as mesmas opções do ENUM do banco -->
    <div class="form-group">
        <label class="form-label" asp-for="Marca">Marca</label>
        <select class="form-control" asp-for="Marca">
            <option value="">-- Selecione a marca --</option>
            @foreach (var marca in new[]{"BYD","Tesla","GWM","Geely","Chery","GAC Aion",
            "Leapmotor","Jaecoo","Toyota","Volvo","Renault",
            "Hyundai","Kia","BMW","Mercedes-Benz","Chevrolet",
            "Fiat","Ford","Volkswagen"})
            {
                <option value="@marca">@marca</option>
            }
        </select>
    </div>

    <!-- CATEGORIA — select com os ENUMs do banco e legenda explicativa -->
    <div class="form-group">
        <label class="form-label" asp-for="Categoria">Categoria / Tecnologia</label>
        <select class="form-control" asp-for="Categoria">
            <option value="">-- Selecione a categoria --</option>
            <option value="BEV">BEV — Battery Electric (100% elétrico)</option>
            <option value="FCEV">FCEV — Fuel Cell Electric (hidrogênio)</option>
            <option value="PHEV">PHEV — Plug-in Hybrid</option>
            <option value="HEV">HEV — Full Hybrid</option>
            <option value="MHEV">MHEV — Mild Hybrid</option>
        </select>
        <span asp-validation-for="Categoria" class="field-validation-error"></span>
    </div>

    <!-- PREÇO -->
    <div class="form-group">
        <label class="form-label" asp-for="Preco">Preço (R$)</label>
        <input class="form-control" asp-for="Preco" type="number" step="0.01" min="0" placeholder="0,00" />
        <span asp-validation-for="Preco" class="field-validation-error"></span>
    </div>

    <!-- DESCRIÇÃO -->
    <div class="form-group">
        <label class="form-label" asp-for="Descricao">Descrição</label>
        <textarea class="form-control" asp-for="Descricao"
                  placeholder="Descreva o carro: autonomia, diferenciais, equipamentos..."></textarea>
    </div>

    <!--
        IMAGEM
        name="imagem" deve ser EXATAMENTE o nome do parâmetro IFormFile? no controller.
        O controller espera: void Criar(Carro model, IFormFile? imagem)
        Se o nome não bater, o arquivo chega null.
    -->
    <div class="form-group">
        <label class="form-label">Imagem do carro</label>
        <input class="form-control" type="file" name="imagem" accept="image/*" />
        <p style="color:var(--muted);font-size:0.75rem;margin-top:0.4rem">
            Formatos aceitos: JPG, PNG, WEBP. A imagem será salva em /imagens/carros/
        </p>
    </div>

    <!-- AÇÕES -->
    <div style="display:flex;gap:0.75rem;margin-top:1.75rem">
        <button type="submit" class="btn btn-primary">Cadastrar carro</button>
        <a asp-action="Gerenciar" class="btn btn-outline">Cancelar</a>
    </div>
</form>

